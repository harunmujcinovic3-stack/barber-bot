# ─────────────────────────────────────────────────────────────
# KLIPPR ENV VARIABELEN
# ─────────────────────────────────────────────────────────────
# Kopieer dit bestand naar .env en vul de waardes in.
# Op Railway: zet deze onder Variables, NIET in .env in de repo.

# OpenAI — GPT-4o-mini voor het AI brein
OPENAI_API_KEY=sk-proj-...

# Twilio WhatsApp — krijg je na sandbox/production setup
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Shop informatie
SHOP_NAME=Kapsalon The Future
BARBER_PHONE=whatsapp:+31600000000

# Dashboard
DASHBOARD_PASSWORD=kiesEenSterkWachtwoord

# Storage — lokaal laat je dit leeg, op Railway wordt het /data (volume mount)
# DATA_DIR=/data

# Server
PORT=3000
